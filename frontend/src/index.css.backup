@import "@fontsource-variable/geist";
@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 222 47% 4%;
    --foreground: 210 40% 98%;
    --card: 222 47% 7%;
    --card-foreground: 210 40% 98%;
    --popover: 222 47% 7%;
    --popover-foreground: 210 40% 98%;
    --primary: 217 91% 60%;
    --primary-foreground: 210 40% 98%;
    --secondary: 217 32% 17%;
    --secondary-foreground: 210 40% 98%;
    --muted: 217 32% 12%;
    --muted-foreground: 215 20% 65%;
    --accent: 183 100% 35%;
    --accent-foreground: 210 40% 98%;
    --destructive: 0 84% 60%;
    --destructive-foreground: 210 40% 98%;
    --border: 217 32% 25%;
    --input: 217 32% 25%;
    --ring: 217 91% 60%;
    --radius: 0.5rem;
    --chart-1: 217 91% 60%;
    --chart-2: 183 100% 35%;
    --chart-3: 142 76% 36%;
    --chart-4: 38 92% 50%;
    --chart-5: 262 83% 58%;
  }
}

* {
  scrollbar-width: thin;
  scrollbar-color: hsl(var(--primary) / 0.4) hsl(var(--background) / 0.4);
}

*::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

*::-webkit-scrollbar-track {
  background: hsl(var(--background) / 0.3);
}

*::-webkit-scrollbar-thumb {
  background: hsl(var(--primary) / 0.4);
  border-radius: 3px;
}

*::-webkit-scrollbar-thumb:hover {
  background: hsl(var(--primary) / 0.6);
}

body {
  margin: 0;
  font-family: 'Geist Variable', system-ui, -apple-system, sans-serif;
  background: hsl(var(--background));
  color: hsl(var(--foreground));
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background-image:
    radial-gradient(ellipse at 20% 50%, hsl(var(--primary) / 0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 50%, hsl(var(--accent) / 0.05) 0%, transparent 50%);
}

@layer components {
  /* Elegant glass morphism cards with shadcn integration */
  .module-card {
    @apply rounded-xl border bg-card/50 backdrop-blur-xl text-card-foreground shadow-lg;
    border-color: hsl(var(--border) / 0.5);
    box-shadow: inset 0 1px 0 hsl(var(--foreground) / 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .module-card:hover {
    border-color: hsl(var(--border) / 0.8);
    box-shadow: inset 0 1px 0 hsl(var(--foreground) / 0.08), 0 8px 32px 0 rgba(31, 38, 135, 0.25);
    transform: translateY(-2px);
  }

  /* Color-themed module cards with glassmorphism */
  .module-card-red {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-blue {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: hsl(var(--primary) / 0.08);
    border-color: hsl(var(--primary) / 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-green {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-amber {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(245, 158, 11, 0.08);
    border-color: rgba(245, 158, 11, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-purple {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(139, 92, 246, 0.08);
    border-color: rgba(139, 92, 246, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-orange {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(249, 115, 22, 0.08);
    border-color: rgba(249, 115, 22, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  .module-card-teal {
    @apply rounded-xl border backdrop-blur-xl shadow-lg;
    background: rgba(20, 184, 166, 0.08);
    border-color: rgba(20, 184, 166, 0.25);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 8px 32px 0 rgba(31, 38, 135, 0.15);
  }

  /* Neon text effects with shadcn variables */
  .neon-text {
    font-weight: 300;
    letter-spacing: 0.05em;
    color: hsl(var(--accent));
    text-shadow: 0 0 10px hsl(var(--accent) / 0.5), 0 0 20px hsl(var(--accent) / 0.3);
  }

  .neon-text-blue {
    font-weight: 300;
    letter-spacing: 0.05em;
    color: hsl(var(--primary));
    text-shadow: 0 0 10px hsl(var(--primary) / 0.5), 0 0 20px hsl(var(--primary) / 0.3);
  }

  /* Elegant gradient shimmer effect */
  .shimmer {
    background: linear-gradient(
      90deg,
      transparent 0%,
      hsl(var(--primary) / 0.1) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: shimmer 2s linear infinite;
  }

  .gradient-border {
    position: relative;
    background: hsl(var(--card));
  }

  .gradient-border::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, hsl(var(--primary) / 0.5), hsl(var(--accent) / 0.5));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* Elegant hover transitions */
  .elegant-hover {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .elegant-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px -10px hsl(var(--primary) / 0.2);
  }

  /* Glow effects */
  .glow-primary {
    box-shadow: 0 0 20px hsl(var(--primary) / 0.3), 0 0 40px hsl(var(--primary) / 0.1);
  }

  .glow-accent {
    box-shadow: 0 0 20px hsl(var(--accent) / 0.3), 0 0 40px hsl(var(--accent) / 0.1);
  }
}

  .btn-neon:hover {
    background-color: rgba(59, 130, 246, 0.2);
    border-color: #3b82f6;
  }

  .btn-primary {
    padding: 0.5rem 1rem;
    background-color: #3b82f6;
    color: white;
    border-radius: 0.375rem;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
  }

  .btn-primary:hover {
    background-color: rgba(59, 130, 246, 0.8);
  }

  /* Terminal-style inputs */
  .input-dark {
    background-color: rgba(15, 22, 41, 0.6);
    border: 1px solid rgba(59, 130, 246, 0.25);
    color: #f1f5f9;
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .input-dark:focus {
    outline: none;
    border-color: rgba(59, 130, 246, 0.8);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.5);
  }

  /* Tag pills */
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 9999px;
    margin-right: 0.375rem;
    margin-bottom: 0.375rem;
    transition: all 0.2s;
  }

  /* Table styles */
  .data-table {
    width: 100%;
    font-size: 0.875rem;
  }

  .data-table thead tr {
    border-bottom: 1px solid rgba(59, 130, 246, 0.25);
  }

  .data-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    color: #64748b;
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .data-table tbody tr {
    border-bottom: 1px solid rgba(59, 130, 246, 0.15);
    transition: colors 0.2s;
  }

  .data-table tbody tr:hover {
    background-color: rgba(15, 22, 41, 0.5);
  }

  .data-table td {
    padding: 0.875rem 1rem;
    color: #f1f5f9;
  }
}

@layer base {
  .theme {
    --font-heading: var(--font-sans);
    --font-sans: 'Geist Variable', sans-serif;
  }
  :root {
    --background: oklch(1 0 0);
    --foreground: oklch(0.145 0 0);
    --card: oklch(1 0 0);
    --card-foreground: oklch(0.145 0 0);
    --popover: oklch(1 0 0);
    --popover-foreground: oklch(0.145 0 0);
    --primary: oklch(0.205 0 0);
    --primary-foreground: oklch(0.985 0 0);
    --secondary: oklch(0.97 0 0);
    --secondary-foreground: oklch(0.205 0 0);
    --muted: oklch(0.97 0 0);
    --muted-foreground: oklch(0.556 0 0);
    --accent: oklch(0.97 0 0);
    --accent-foreground: oklch(0.205 0 0);
    --destructive: oklch(0.577 0.245 27.325);
    --border: oklch(0.922 0 0);
    --input: oklch(0.922 0 0);
    --ring: oklch(0.708 0 0);
    --chart-1: oklch(0.87 0 0);
    --chart-2: oklch(0.556 0 0);
    --chart-3: oklch(0.439 0 0);
    --chart-4: oklch(0.371 0 0);
    --chart-5: oklch(0.269 0 0);
    --radius: 0.625rem;
    --sidebar: oklch(0.985 0 0);
    --sidebar-foreground: oklch(0.145 0 0);
    --sidebar-primary: oklch(0.205 0 0);
    --sidebar-primary-foreground: oklch(0.985 0 0);
    --sidebar-accent: oklch(0.97 0 0);
    --sidebar-accent-foreground: oklch(0.205 0 0);
    --sidebar-border: oklch(0.922 0 0);
    --sidebar-ring: oklch(0.708 0 0);
  }
  .dark {
    --background: oklch(0.145 0 0);
    --foreground: oklch(0.985 0 0);
    --card: oklch(0.205 0 0);
    --card-foreground: oklch(0.985 0 0);
    --popover: oklch(0.205 0 0);
    --popover-foreground: oklch(0.985 0 0);
    --primary: oklch(0.922 0 0);
    --primary-foreground: oklch(0.205 0 0);
    --secondary: oklch(0.269 0 0);
    --secondary-foreground: oklch(0.985 0 0);
    --muted: oklch(0.269 0 0);
    --muted-foreground: oklch(0.708 0 0);
    --accent: oklch(0.269 0 0);
    --accent-foreground: oklch(0.985 0 0);
    --destructive: oklch(0.704 0.191 22.216);
    --border: oklch(1 0 0 / 10%);
    --input: oklch(1 0 0 / 15%);
    --ring: oklch(0.556 0 0);
    --chart-1: oklch(0.87 0 0);
    --chart-2: oklch(0.556 0 0);
    --chart-3: oklch(0.439 0 0);
    --chart-4: oklch(0.371 0 0);
    --chart-5: oklch(0.269 0 0);
    --sidebar: oklch(0.205 0 0);
    --sidebar-foreground: oklch(0.985 0 0);
    --sidebar-primary: oklch(0.488 0.243 264.376);
    --sidebar-primary-foreground: oklch(0.985 0 0);
    --sidebar-accent: oklch(0.269 0 0);
    --sidebar-accent-foreground: oklch(0.985 0 0);
    --sidebar-border: oklch(1 0 0 / 10%);
    --sidebar-ring: oklch(0.556 0 0);
  }
  html {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
}

@keyframes slideIn {
  0% {
    opacity: 0;
    transform: translateX(-20px);
  }
  100% {
    opacity: 1;
    transform: translateX(0);
  }
}

/* Remove default focus outline on NavLinks */
a:focus,
a:focus-visible {
  outline: none !important;
  box-shadow: none !important;
}